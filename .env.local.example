# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# GitHub OAuth App (create at github.com/settings/developers)
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret_never_prefix_with_NEXT_PUBLIC
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_client_id

# GitHub repo to publish posts to
NEXT_PUBLIC_GITHUB_REPO=yourusername/your-blog-repo
NEXT_PUBLIC_GITHUB_BRANCH=main

# Giscus comments (generate at giscus.app after enabling GitHub Discussions)
NEXT_PUBLIC_GISCUS_REPO=yourusername/your-blog-repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxxxx
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOxxxxxxxx
